# FastAPI Configuration
PROJECT_NAME="Ledgerline Finance API"
API_V1_STR="/api/v1"
SECRET_KEY="generate-a-long-random-secure-secret-key-here"
ACCESS_TOKEN_EXPIRE_MINUTES=11520  # 8 days

# Database Configuration
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ledgerline
POSTGRES_PORT=5432

# Third-Party APIs (for models and agent)
OPENAI_API_KEY=your-openai-api-key-here
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com
